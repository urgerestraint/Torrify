{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist-electron",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "electron"
    ]
  },
  "include": [
    "electron/**/*"
  ],
  "exclude": [
    "electron/__tests__"
  ]
}